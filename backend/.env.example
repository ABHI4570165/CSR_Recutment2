# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/mha_quiz
# Atlas (production):
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/mha_quiz?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=another_separate_long_random_admin_secret_32_chars

# ── Admin Credentials ───────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123!

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Redis Cloud (production):
# REDIS_URL=redis://:password@host:port

# ── Email ────────────────────────────────────────────────
# PREFERRED ON RENDER: HTTPS API (Render blocks outbound SMTP ports 25/465/587).
# When BREVO_API_KEY is set, mail is sent via https://api.brevo.com (port 443).
# Get it from Brevo → SMTP & API → API Keys (starts with "xkeysib-").
BREVO_API_KEY=
# SMTP fallback (used locally / where SMTP is allowed). EMAIL_FROM is required for both.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_brevo_smtp_login
EMAIL_PASS=your_brevo_smtp_key
EMAIL_FROM=MH Academy <your_verified_sender@yourdomain.com>
# Connection timeouts (so a blocked port fails fast instead of hanging)
EMAIL_CONN_TIMEOUT=10000
EMAIL_GREET_TIMEOUT=10000
EMAIL_SOCKET_TIMEOUT=20000
EMAIL_API_TIMEOUT=15000
# Invitation queue tuning (campus drives)
EMAIL_POLL_INTERVAL_MS=30000
EMAIL_BATCH_SIZE=25
EMAIL_MAX_ATTEMPTS=3
EMAIL_RATE_LIMIT=5
EMAIL_MAX_CONNECTIONS=5

# ── Frontend URL (used to build invitation links: FRONTEND_URL/assessment/<token>) ──
FRONTEND_URL=http://localhost:5173
# Optional second allowed origin (e.g. Hostinger custom domain)
# FRONTEND_URL_2=https://yourdomain.com

# ── MongoDB connection pool (load handling) ─────────────
MONGO_POOL_SIZE=20
MONGO_MIN_POOL=2

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
