# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/mha_quiz
# Atlas (production):
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/mha_quiz?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=another_separate_long_random_admin_secret_32_chars

# ── Admin Credentials ───────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123!

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Redis Cloud (production):
# REDIS_URL=redis://:password@host:port

# ── Email (SMTP) ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Mandi Hariyanna Academy <your_email@gmail.com>

# ── Frontend URL (for email links) ──────────────────────
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
