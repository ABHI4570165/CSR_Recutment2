# ── Copy to .env and fill in real values. NEVER commit the real .env. ──
PORT=8080
NODE_ENV=production
MONGO_URI=
JWT_SECRET=
JWT_EXPIRES_IN=1d
ADMIN_JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Optional read-only VIEWER login (sees the dashboard, cannot create/edit/delete).
VIEWER_USERNAME=
VIEWER_PASSWORD=
FRONTEND_URL=https://quizportal.mandi-hariyanna-academy.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Email (Brevo SMTP) ──────────────────────────────────
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_BATCH_SIZE=25
EMAIL_MAX_ATTEMPTS=3

# ── Cloudinary (walk-in resume storage) ─────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=mh_resumes

# ── Mongo connection pool ───────────────────────────────
MONGO_POOL_SIZE=20
MONGO_MIN_POOL=2

# ── Optional ────────────────────────────────────────────
# BREVO_API_KEY=        # xkeysib-... use Brevo HTTPS API if SMTP port 587 is blocked
# WHATSAPP_GROUP_URL=   # overrides the WhatsApp group link in the thank-you email
# REDIS_URL=            # leave blank on Hostinger — caching falls back to DB automatically
